<% content_for :title, "장바구니" %>

<div class="container py-5">
  <h1 class="section-title mb-4">장바구니</h1>

  <% if @cart.cart_items.any? %>
    <div class="row">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="table-responsive">
            <table class="table table-borderless mb-0">
              <thead class="bg-light">
                <tr>
                  <th class="ps-4">상품</th>
                  <th>가격</th>
                  <th>수량</th>
                  <th>합계</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @cart.cart_items.each do |item| %>
                  <tr>
                    <td class="ps-4">
                      <div class="d-flex align-items-center gap-3">
                        <% if item.product.image.attached? %>
                          <%= image_tag item.product.image, style: "width:60px;height:60px;object-fit:cover;", class: "rounded-3" %>
                        <% else %>
                          <div style="width:60px;height:60px;background:#f8f9fa;" class="rounded-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-image text-muted"></i>
                          </div>
                        <% end %>
                        <div>
                          <h6 class="mb-0"><%= item.product.name %></h6>
                          <small class="text-muted"><%= item.product.seller.store_name %></small>
                        </div>
                      </div>
                    </td>
                    <td><%= number_to_currency(item.product.discounted_price, unit:"₩", precision:0) %></td>
                    <td>
                      <%= form_with url: cart_item_path(item), method: :patch, local: true do |f| %>
                        <div class="input-group" style="width:120px;">
                          <%= f.number_field :quantity, value: item.quantity, min: 1, class: "form-control form-control-sm", onchange: "this.form.submit()" %>
                        </div>
                      <% end %>
                    </td>
                    <td><%= number_to_currency(item.subtotal, unit:"₩", precision:0) %></td>
                    <td>
                      <%= button_to cart_item_path(item), method: :delete, class: "btn btn-sm btn-outline-danger", data: { confirm: "삭제하시겠습니까?" } do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body">
            <h5 class="fw-semibold mb-3">주문 요약</h5>
            <div class="d-flex justify-content-between mb-2">
              <span>상품 금액</span>
              <span><%= number_to_currency(@cart.total_price, unit:"₩", precision:0) %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>배송비</span>
              <span>무료</span>
            </div>
            <hr>
            <div class="d-flex justify-content-between mb-3">
              <strong>총 결제 금액</strong>
              <strong class="text-brand-accent"><%= number_to_currency(@cart.total_price, unit:"₩", precision:0) %></strong>
            </div>
            <%= link_to "주문하기", "#", class: "btn btn-primary w-100", onclick: "alert('주문 기능은 준비 중입니다 😊'); return false;" %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="empty-state">
      <i class="bi bi-cart-empty empty-icon d-block"></i>
      <h5>장바구니가 비어있습니다</h5>
      <p class="text-muted small">상품을 담아보세요!</p>
      <%= link_to "쇼핑 계속하기", products_path, class: "btn btn-primary mt-3" %>
    </div>
  <% end %>
</div>