<% content_for :title, "비밀번호 찾기" %>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="text-center mb-4">
      <div class="mb-3">
        <i class="bi bi-envelope-exclamation fs-1 text-brand-accent"></i>
      </div>
      <h2 class="auth-title">비밀번호 찾기</h2>
      <p class="text-muted">가입하신 이메일을 입력하시면<br>비밀번호 재설정 링크를 보내드립니다.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, "이메일", class: "form-label fw-medium" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", placeholder: "example@email.com" %>
      </div>

      <div class="d-grid gap-2">
        <%= f.submit "비밀번호 재설정 메일 보내기", class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>

    <div class="text-center mt-4">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>