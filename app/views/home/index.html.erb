<% content_for :title, "홈" %>

<!-- Hero Section -->
<section class="hero-section">
  <div class="container position-relative" style="z-index:1">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <p class="section-label fade-in-up">취향 맞춤형 쇼핑 플랫폼</p>
        <h1 class="hero-title fade-in-up delay-1">
          당신의 키워드로<br>
          <span class="hero-accent">맞춤 상품</span>을<br>
          찾아드립니다
        </h1>
        <p class="hero-subtitle fade-in-up delay-2">
          관심 키워드를 선택하면 취향에 딱 맞는 상품을 실시간으로 추천해드립니다.
        </p>

        <% if user_signed_in? && current_user.keywords.any? %>
          <div class="keyword-tags-scroll fade-in-up delay-3">
            <span style="font-size:0.8rem;color:rgba(255,255,255,0.5);align-self:center;margin-right:0.25rem;">내 키워드:</span>
            <% current_user.keywords.each do |kw| %>
              <a href="<%= products_path(keyword: kw.name) %>" class="keyword-tag">
                <i class="bi bi-hash" style="font-size:0.7rem"></i><%= kw.name %>
              </a>
            <% end %>
            <%= link_to edit_keywords_path, class: "keyword-tag" do %>
              <i class="bi bi-plus-circle" style="font-size:0.7rem"></i>키워드 편집
            <% end %>
          </div>
        <% else %>
          <div class="keyword-tags-scroll fade-in-up delay-3">
            <span style="font-size:0.8rem;color:rgba(255,255,255,0.5);align-self:center;">인기 키워드:</span>
            <% Keyword.popular.limit(8).each do |kw| %>
              <a href="<%= products_path(keyword: kw.name) %>" class="keyword-tag">
                <i class="bi bi-hash" style="font-size:0.7rem"></i><%= kw.name %>
              </a>
            <% end %>
          </div>
          <div class="mt-3 fade-in-up delay-4">
            <%= link_to "키워드 설정하고 맞춤 추천받기 →", user_signed_in? ? edit_keywords_path : new_user_registration_path, class: "btn btn-warning fw-semibold mt-2", style: "border-radius:50px;padding:0.6rem 1.8rem;" %>
          </div>
        <% end %>
      </div>

      <div class="col-lg-5 d-none d-lg-block">
        <div class="hero-visual position-relative">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;transform:perspective(800px) rotateY(-10deg) rotateX(5deg);">
            <% @featured_products.first(4).each_with_index do |p, i| %>
              <div class="card border-0 shadow-lg" style="border-radius:14px;overflow:hidden;">
                <% if p.image.attached? %>
                  <%= image_tag p.image, style: "height:120px;object-fit:cover;width:100%;" %>
                <% else %>
                  <div style="height:120px;background:rgba(0,0,0,0.1);display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-image fs-2"></i>
                  </div>
                <% end %>
                <div style="padding:0.6rem 0.75rem;background:white;">
                  <p style="font-size:0.7rem;font-weight:600;margin:0;color:#333;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;"><%= p.name %></p>
                  <p style="font-size:0.75rem;font-weight:700;margin:0;color:#1a1a2e;"><%= number_to_currency(p.price, unit:"₩", precision:0) %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 맞춤 추천 상품 -->
<% if user_signed_in? && current_user.keywords.any? && @matched_products.any? %>
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <p class="section-label mb-1">AI 매칭</p>
        <h2 class="section-title mb-0">내 취향 맞춤 추천</h2>
        <p class="text-muted small mt-1">
          <%= current_user.keywords.pluck(:name).map{|n|"##{n}"}.join(" ") %> 키워드 기반
        </p>
      </div>
      <%= link_to "전체 보기 →", products_path(matched: true), class: "btn btn-outline-secondary btn-sm" %>
    </div>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
      <% @matched_products.each do |product| %>
        <div class="col">
          <%= render 'products/card', product: product, matched: true, user_keywords: current_user.keywords.pluck(:name) %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% elsif !user_signed_in? %>
<!-- 비로그인 CTA -->
<section class="py-5 bg-brand-soft">
  <div class="container text-center">
    <div style="max-width:500px;margin:0 auto;padding:3rem 1rem;">
      <i class="bi bi-stars fs-1 text-brand-accent mb-3 d-block"></i>
      <h3 class="section-title">키워드를 설정하고<br>맞춤 쇼핑 시작하기</h3>
      <p class="text-muted mt-2 mb-4">회원가입 후 관심 키워드를 설정하면<br>딱 맞는 상품만 골라서 보여드립니다.</p>
      <%= link_to "무료 회원가입", new_user_registration_path, class: "btn btn-primary btn-lg me-2", style: "border-radius:50px;" %>
      <%= link_to "둘러보기", products_path, class: "btn btn-outline-secondary btn-lg", style: "border-radius:50px;" %>
    </div>
  </div>
</section>
<% end %>

<!-- 인기 상품 -->
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <p class="section-label mb-1">베스트</p>
        <h2 class="section-title mb-0">인기 상품</h2>
      </div>
      <%= link_to "전체 상품 보기 →", products_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
      <% @popular_products.each do |product| %>
        <div class="col">
          <%= render 'products/card', product: product, matched: false %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- 카테고리 둘러보기 -->
<section class="py-5 bg-brand-soft">
  <div class="container">
    <div class="text-center mb-4">
      <p class="section-label mb-1">카테고리</p>
      <h2 class="section-title mb-0">무엇을 찾고 계신가요?</h2>
    </div>
    <div class="row g-3 justify-content-center">
      <% Keyword.grouped.each do |category, keywords| %>
      <div class="col-6 col-md-3 col-lg-2">
        <a href="<%= products_path(category: category) %>" class="d-block text-center text-decoration-none p-3" style="background:white;border-radius:16px;border:1.5px solid rgba(0,0,0,0.06);transition:all 0.2s;">
          <i class="bi bi-<%= keywords.first.icon %> fs-2 d-block mb-2 text-brand-accent"></i>
          <span style="font-size:0.85rem;font-weight:600;color:#1a1a2e;"><%= category %></span>
        </a>
      </div>
    <% end %>
    </div>
  </div>
</section>