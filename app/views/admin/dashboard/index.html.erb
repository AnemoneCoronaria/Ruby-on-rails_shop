<% content_for :title, "관리자 대시보드" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title mb-0">관리자 대시보드</h1>
    <p class="text-muted mb-0"><%= Time.current.strftime("%Y년 %m월 %d일") %></p>
  </div>

  <!-- 통계 카드 -->
  <div class="row g-4 mb-5">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm rounded-4 p-3">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <p class="text-muted small mb-1">전체 회원</p>
            <h2 class="mb-0 fw-bold"><%= @total_users %></h2>
          </div>
          <i class="bi bi-people fs-1 text-brand-accent opacity-50"></i>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm rounded-4 p-3">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <p class="text-muted small mb-1">판매자</p>
            <h2 class="mb-0 fw-bold"><%= @total_sellers %></h2>
          </div>
          <i class="bi bi-shop fs-1 text-brand-accent opacity-50"></i>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm rounded-4 p-3">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <p class="text-muted small mb-1">구매자</p>
            <h2 class="mb-0 fw-bold"><%= @total_buyers %></h2>
          </div>
          <i class="bi bi-person fs-1 text-brand-accent opacity-50"></i>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm rounded-4 p-3">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <p class="text-muted small mb-1">총 상품</p>
            <h2 class="mb-0 fw-bold"><%= @total_products %></h2>
          </div>
          <i class="bi bi-box fs-1 text-brand-accent opacity-50"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- 최근 활동 -->
  <div class="row g-4">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-semibold mb-0">최근 등록 상품</h5>
        </div>
        <div class="card-body p-4 pt-0">
          <% if @recent_products.any? %>
            <div class="list-group list-group-flush">
              <% @recent_products.each do |product| %>
                <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                  <div>
                    <p class="mb-0 fw-semibold"><%= product.name %></p>
                    <small class="text-muted"><%= product.seller.store_name || product.seller.name %></small>
                  </div>
                  <span class="badge bg-light text-dark"><%= number_to_currency(product.price, unit: "₩", precision: 0) %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted text-center py-3">등록된 상품이 없습니다.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="fw-semibold mb-0">최근 문의</h5>
        </div>
        <div class="card-body p-4 pt-0">
          <% if @recent_inquiries.any? %>
            <div class="list-group list-group-flush">
              <% @recent_inquiries.each do |inquiry| %>
                <div class="list-group-item px-0 py-2">
                  <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                      <p class="mb-0 fw-semibold"><%= inquiry.title %></p>
                      <small class="text-muted"><%= inquiry.user.name %> · <%= inquiry.created_at.strftime("%Y.%m.%d") %></small>
                    </div>
                    <span class="inquiry-badge <%= inquiry.status %>" style="font-size:0.7rem;">
                      <%= inquiry.status == 'open' ? '답변 대기' : inquiry.status == 'answered' ? '답변 완료' : '처리 완료' %>
                    </span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted text-center py-3">등록된 문의가 없습니다.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>