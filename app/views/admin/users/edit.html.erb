<% content_for :title, "회원 수정" %>

<div class="container py-5" style="max-width:600px;">
  <h1 class="section-title mb-4">회원 수정</h1>

  <div class="card border-0 shadow-sm rounded-4 p-4">
    <%= form_with model: @user, url: admin_user_path(@user), method: :patch, local: true do |f| %>
      <div class="mb-3">
        <%= f.label :name, "이름", class: "form-label fw-medium" %>
        <%= f.text_field :name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :email, "이메일", class: "form-label fw-medium" %>
        <%= f.email_field :email, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :role, "역할", class: "form-label fw-medium" %>
        <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "form-select" %>
      </div>

      <div class="mb-4">
        <%= f.label :store_name, "스토어명", class: "form-label fw-medium" %>
        <%= f.text_field :store_name, class: "form-control", placeholder: "판매자만 입력" %>
      </div>

      <div class="d-flex gap-2 justify-content-end">
        <%= link_to "취소", admin_users_path, class: "btn btn-outline-secondary" %>
        <%= f.submit "수정 저장", class: "btn btn-primary px-4" %>
      </div>
    <% end %>
  </div>
</div>