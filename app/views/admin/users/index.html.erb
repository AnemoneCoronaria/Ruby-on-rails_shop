<% content_for :title, "회원 관리" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-title mb-0">회원 관리</h1>
    <p class="text-muted mb-0">총 <%= @users.total_count %>명</p>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">ID</th>
            <th>이름</th>
            <th>이메일</th>
            <th>역할</th>
            <th>스토어명</th>
            <th>가입일</th>
            <th class="pe-4">관리</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td class="ps-4"><%= user.id %></td>
              <td><%= user.name %></td>
              <td><%= user.email %></td>
              <td>
                <span class="badge <%= user.admin? ? 'bg-danger' : (user.seller? ? 'bg-warning' : 'bg-secondary') %>">
                  <%= user.role %>
                </span>
              </td>
              <td><%= user.store_name || '-' %></td>
              <td><%= user.created_at.strftime("%Y.%m.%d") %></td>
              <td class="pe-4">
                <%= link_to edit_admin_user_path(user), class: "btn btn-sm btn-outline-secondary me-1" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= button_to admin_user_path(user), method: :delete, class: "btn btn-sm btn-outline-danger", data: { confirm: "정말 삭제하시겠습니까?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="d-flex justify-content-center mt-4">
    <%= paginate @users %>
  </div>
</div>