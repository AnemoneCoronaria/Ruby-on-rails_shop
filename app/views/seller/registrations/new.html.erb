<% content_for :title, "판매자 등록" %>

<div class="container py-5" style="max-width:600px;">
  <h1 class="section-title text-center mb-4">판매자 등록</h1>
  <p class="text-center text-muted mb-5">스토어 정보를 입력해주세요</p>

  <div class="card border-0 shadow-sm rounded-4 p-4">
    <%= form_with model: @user, url: seller_registrations_path, method: :post, local: true do |f| %>
      <div class="mb-4">
        <%= f.label :store_name, "스토어 이름", class: "form-label fw-medium" %>
        <%= f.text_field :store_name, class: "form-control", placeholder: "스토어 이름을 입력하세요", required: true %>
        <div class="form-text">고객에게 보여질 스토어 이름입니다.</div>
      </div>

      <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        판매자 등록 후에는 상품을 등록하고 판매할 수 있습니다.
      </div>

      <div class="d-flex gap-2 justify-content-end">
        <%= link_to "취소", root_path, class: "btn btn-outline-secondary" %>
        <%= f.submit "판매자 등록하기", class: "btn btn-primary px-4" %>
      </div>
    <% end %>
  </div>
</div>