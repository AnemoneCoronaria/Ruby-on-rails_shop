<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= content_for?(:title) ? yield(:title) + " | " : "" %>MARKETO 관리자</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
</head>
<body>

<nav class="navbar navbar-expand-lg sticky-top bg-dark" data-bs-theme="dark">
  <div class="container">
    <a class="navbar-brand fw-bold" href="<%= admin_dashboard_path %>">
      <span class="brand-mark">M</span>ARKETO Admin
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <i class="bi bi-list"></i>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto gap-2">
        <li class="nav-item"><%= link_to "대시보드", admin_dashboard_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "회원 관리", admin_users_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "상품 관리", admin_products_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "문의 관리", admin_inquiries_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "사이트로 이동", root_path, class: "nav-link text-warning" %></li>
        <li class="nav-item"><%= button_to "로그아웃", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-outline-light ms-2" %></li>
      </ul>
    </div>
  </div>
</nav>

<% if notice %>
  <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
    <div class="container"><%= notice %></div>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% end %>
<% if alert %>
  <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
    <div class="container"><%= alert %></div>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% end %>

<main class="py-4"><%= yield %></main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
</body>
</html>