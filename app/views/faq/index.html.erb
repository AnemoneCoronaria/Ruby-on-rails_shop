<% content_for :title, "자주 묻는 질문" %>

<div class="container py-5" style="max-width:800px;">
  <h1 class="section-title text-center mb-4">자주 묻는 질문</h1>
  <p class="text-center text-muted mb-5">자주 묻는 질문들을 모아두었습니다.</p>

  <div class="accordion" id="faqAccordion">
    <% @faqs.each_with_index do |faq, index| %>
      <div class="accordion-item mb-3 border rounded-3 overflow-hidden">
        <h2 class="accordion-header">
          <button class="accordion-button <%= 'collapsed' if index > 0 %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>">
            <strong><%= faq[:question] %></strong>
          </button>
        </h2>
        <div id="collapse<%= index %>" class="accordion-collapse collapse <%= 'show' if index == 0 %>" data-bs-parent="#faqAccordion">
          <div class="accordion-body">
            <%= faq[:answer] %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-5">
    <p>더 궁금한 점이 있으신가요?</p>
    <%= link_to "문의 게시판에 질문하기", inquiries_path, class: "btn btn-primary" %>
  </div>
</div>