<% content_for :title, @product.name %>

<div class="container py-5">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "홈", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "전체 상품", products_path %></li>
      <li class="breadcrumb-item active"><%= @product.name %></li>
    </ol>
  </nav>

  <div class="row g-5">
    <!-- 상품 이미지 -->
    <div class="col-lg-6">
      <div class="rounded-4 overflow-hidden bg-light position-relative" style="aspect-ratio:4/3;">
        <% if @product.image.attached? %>
          <%= image_tag @product.image, class: "w-100 h-100", style: "object-fit:cover;" %>
        <% else %>
          <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
            <i class="bi bi-image" style="font-size:4rem;opacity:0.3;"></i>
          </div>
        <% end %>
        
        <!-- 할인 배지 (이미지 위) -->
        <% if @product.discount_rate > 0 %>
          <div style="position: absolute; top: 20px; left: 20px; background: #e74c3c; color: white; font-size: 1rem; font-weight: 700; padding: 6px 14px; border-radius: 30px; z-index: 2;">
            <%= @product.discount_rate %>% OFF
          </div>
        <% end %>
      </div>
    </div>

    <!-- 상품 정보 -->
    <div class="col-lg-6">
      <p class="text-muted small mb-1">
        <i class="bi bi-shop me-1"></i><%= @product.seller.store_name || @product.seller.name %>
      </p>
      
      <h1 style="font-family:'DM Sans',sans-serif;font-size:1.8rem;font-weight:700;line-height:1.25; margin-bottom: 1rem;">
        <%= @product.name %>
      </h1>

      <!-- 가격 정보 (개선된 버전) -->
      <div class="mb-4">
        <% if @product.discount_rate > 0 %>
          <div class="d-flex align-items-baseline gap-3 flex-wrap">
            <span style="font-size: 2.2rem; font-weight: 800; color: #e74c3c;">
              <%= number_to_currency(@product.discounted_price, unit:"₩", precision:0) %>
            </span>
            <span class="text-muted text-decoration-line-through" style="font-size: 1.2rem;">
              <%= number_to_currency(@product.price, unit:"₩", precision:0) %>
            </span>
            <span class="badge bg-danger" style="font-size: 0.9rem; padding: 5px 12px;">
              <%= @product.discount_rate %>% 할인
            </span>
          </div>
          <div class="mt-2">
            <span class="small text-muted">
              <i class="bi bi-tag"></i> 할인된 가격으로 만나보세요!
            </span>
          </div>
        <% else %>
          <div class="d-flex align-items-baseline gap-2">
            <span style="font-size: 2.2rem; font-weight: 700; color: #1a1a2e;">
              <%= number_to_currency(@product.price, unit:"₩", precision:0) %>
            </span>
          </div>
        <% end %>
      </div>

      <!-- 키워드 태그 -->
      <div class="d-flex flex-wrap gap-2 mb-4">
        <% @product.keywords.each do |kw| %>
          <%= link_to products_path(keyword: kw.name), class: "tag-chip text-decoration-none", style: "background: #f8f6f0; padding: 5px 12px; border-radius: 20px; font-size: 0.8rem;" do %>
            #<%= kw.name %>
          <% end %>
        <% end %>
      </div>

      <!-- 상품 설명 -->
      <div class="mb-4 p-3 rounded-3" style="background: #f8f9fa; border: 1px solid #e9ecef;">
        <div style="color:#444; line-height:1.8; font-size:0.95rem;">
          <%= simple_format @product.description %>
        </div>
      </div>

      <!-- 재고 정보 -->
      <div class="rounded-3 p-3 mb-4" style="background:#f8f6f0; border:1px solid rgba(0,0,0,0.06);">
        <div class="d-flex justify-content-between small">
          <span class="text-muted"><i class="bi bi-box-seam me-1"></i>재고</span>
          <strong class="<%= @product.stock <= 5 ? 'text-danger' : 'text-success' %>">
            <%= @product.stock > 0 ? "#{@product.stock}개 남음" : "품절" %>
            <% if @product.stock <= 5 && @product.stock > 0 %>
              <span class="ms-1 badge bg-warning text-dark">마감 임박!</span>
            <% end %>
          </strong>
        </div>
      </div>

      <!-- 수정/삭제 버튼 (판매자만) -->
      <div class="d-flex gap-2 mb-4">
        <% if user_signed_in? && current_user == @product.seller %>
          <%= link_to edit_product_path(@product), class: "btn btn-outline-secondary" do %>
            <i class="bi bi-pencil me-1"></i>수정
          <% end %>
          <%= button_to product_path(@product), method: :delete, class: "btn btn-outline-danger", data: { confirm: "정말 삭제하시겠습니까?" } do %>
            <i class="bi bi-trash me-1"></i>삭제
          <% end %>
        <% end %>
      </div>

      <!-- 구매 버튼 -->
      <% if @product.stock > 0 %>
        <div class="d-flex gap-3">
          <div class="input-group" style="max-width:130px;">
            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(-1)" style="border-radius: 8px 0 0 8px;">-</button>
            <input type="number" class="form-control text-center" value="1" min="1" max="<%= @product.stock %>" id="qty" style="border-radius: 0;">
            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(1)" style="border-radius: 0 8px 8px 0;">+</button>
          </div>
          <%= button_to cart_items_path, method: :post, params: { product_id: @product.id, quantity: "qty" }, class: "btn btn-outline-primary flex-fill py-2", style: "border-radius: 8px;" do %>
            <i class="bi bi-cart-plus me-1"></i>장바구니 담기
          <% end %>
          <%= link_to "#", class: "btn btn-primary flex-fill py-2", style: "border-radius: 8px;", onclick: "alert('주문 기능은 준비 중입니다 😊'); return false;" do %>
            <i class="bi bi-credit-card me-1"></i>바로 구매
          <% end %>
        </div>
        <p class="text-muted small mt-2">
          <i class="bi bi-info-circle"></i> 장바구니에 담으면 다른 상품과 함께 결제할 수 있습니다.
        </p>
      <% else %>
        <button class="btn btn-secondary w-100 py-2" disabled style="border-radius: 8px;">
          <i class="bi bi-x-circle me-1"></i>품절
        </button>
      <% end %>
    </div>
  </div>

  <!-- 관련 상품 -->
  <% if @related_products.present? && @related_products.any? %>
    <hr class="my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="section-title mb-0">관련 상품</h3>
      <%= link_to "더 보기 →", products_path(keywords: @product.keyword_names.join(',')), class: "text-decoration-none" %>
    </div>
    <div class="row row-cols-2 row-cols-md-4 g-4">
      <% @related_products.each do |p| %>
        <div class="col">
          <%= render 'products/card', product: p, matched: false %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<script>
function changeQty(delta) {
  const input = document.getElementById('qty');
  let val = parseInt(input.value) + delta;
  const max = parseInt(input.getAttribute('max'));
  val = Math.max(1, Math.min(max, val));
  input.value = val;
}
</script>