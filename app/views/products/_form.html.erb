<% content_for :title, @product.new_record? ? "상품 등록" : "상품 수정" %>

<div class="bg-brand-soft py-4 border-bottom">
  <div class="container">
    <h1 class="section-title mb-0"><%= @product.new_record? ? "상품 등록" : "상품 수정" %></h1>
  </div>
</div>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <%= form_with model: @product, local: true, multipart: true do |f| %>
        <% if @product.errors.any? %>
          <div class="alert alert-danger rounded-3">
            <strong>오류가 있습니다:</strong>
            <ul class="mb-0 mt-1">
              <% @product.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-semibold mb-3">기본 정보</h5>
          <div class="mb-3">
            <%= f.label :name, "상품명", class: "form-label fw-medium" %>
            <%= f.text_field :name, class: "form-control", placeholder: "상품 이름을 입력하세요" %>
          </div>
          <div class="mb-3">
            <%= f.label :description, "상품 설명", class: "form-label fw-medium" %>
            <%= f.text_area :description, rows: 5, class: "form-control", placeholder: "상품에 대해 자세히 설명해주세요" %>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <%= f.label :price, "판매가 (원)", class: "form-label fw-medium" %>
              <%= f.number_field :price, class: "form-control", placeholder: "0", min: 0 %>
            </div>
            <div class="col-md-6">
              <%= f.label :stock, "재고 수량", class: "form-label fw-medium" %>
              <%= f.number_field :stock, class: "form-control", placeholder: "0", min: 0 %>
            </div>
          </div>
          <div class="mt-3">
            <%= f.label :discount_rate, "할인율 (%)", class: "form-label fw-medium" %>
            <%= f.number_field :discount_rate, class: "form-control", placeholder: "0", min: 0, max: 99 %>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-semibold mb-3">상품 이미지</h5>
          <% if @product.image.attached? %>
            <div class="mb-3">
              <%= image_tag @product.image, style: "max-height:200px;object-fit:cover;", class: "rounded-3" %>
              <p class="text-muted small mt-1">현재 이미지. 새 이미지를 선택하면 교체됩니다.</p>
            </div>
          <% end %>
          <%= f.file_field :image, class: "form-control", accept: "image/*" %>
          <p class="text-muted small mt-1">JPG, PNG, WEBP 지원. 최대 5MB.</p>
        </div>

        <!-- 키워드 태그 선택 -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
          <h5 class="fw-semibold mb-1">키워드 태그 설정</h5>
          <p class="text-muted small mb-3">상품에 해당하는 키워드를 선택하세요.</p>

          <% if Keyword.any? %>
            <% Keyword.grouped.each do |category, keywords| %>
              <div class="mb-3">
                <h6 class="fw-semibold mb-2"><%= category %></h6>
                <div class="keyword-picker-grid">
                  <% keywords.each do |kw| %>
                    <label class="m-0" style="cursor:pointer;">
                      <%= check_box_tag "product[keyword_ids][]", kw.id, @product.keyword_ids.include?(kw.id), id: "keyword_#{kw.id}", style: "display:none;" %>
                      <span class="keyword-picker-btn <%= 'selected' if @product.keyword_ids.include?(kw.id) %>"
                            onclick="this.previousElementSibling.click(); this.classList.toggle('selected')">
                        #<%= kw.name %>
                      </span>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="text-muted">키워드가 없습니다. 관리자에게 문의하세요.</p>
          <% end %>

          <div class="text-muted small mt-2">
            <i class="bi bi-info-circle me-1"></i>선택된 키워드: <strong id="keyword-count"><%= @product.keywords.count %></strong>개
          </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
          <%= link_to "취소", products_path, class: "btn btn-outline-secondary" %>
          <%= f.submit @product.new_record? ? "상품 등록하기" : "저장하기", class: "btn btn-primary px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const checkboxes = document.querySelectorAll('input[name="product[keyword_ids][]"]');
  const countEl = document.getElementById('keyword-count');
  
  function updateCount() {
    const checked = document.querySelectorAll('input[name="product[keyword_ids][]"]:checked').length;
    if (countEl) countEl.textContent = checked;
  }
  
  checkboxes.forEach(function(cb) {
    cb.addEventListener('change', updateCount);
  });
  
  updateCount();
});
</script>