<% content_for :title, @inquiry.title %>

<div class="container py-5" style="max-width:760px;">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "문의 게시판", inquiries_path %></li>
      <li class="breadcrumb-item active">문의 상세</li>
    </ol>
  </nav>

  <!-- Inquiry Detail -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
    <div class="d-flex align-items-start justify-content-between mb-3">
      <div>
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="inquiry-badge <%= @inquiry.status %>">
            <%= @inquiry.status == 'open' ? '답변 대기' : @inquiry.status == 'answered' ? '답변 완료' : '처리 완료' %>
          </span>
          <% if @inquiry.category.present? %>
            <span class="badge bg-light text-muted border" style="font-size:0.7rem;"><%= @inquiry.category %></span>
          <% end %>
          <% if @inquiry.is_private %>
            <span class="badge bg-secondary" style="font-size:0.7rem;">
              <i class="bi bi-lock"></i> 비공개
            </span>
          <% end %>
        </div>
        <h2 style="font-family:'DM Sans',sans-serif;font-size:1.3rem;font-weight:700;"><%= @inquiry.title %></h2>
        <p class="text-muted small mb-0">
          <i class="bi bi-person-circle me-1"></i><%= @inquiry.user.name %> &nbsp;·&nbsp;
          <i class="bi bi-clock me-1"></i><%= @inquiry.created_at.strftime("%Y년 %m월 %d일 %H:%M") %>
        </p>
      </div>
      <% if user_signed_in? && current_user == @inquiry.user %>
        <div class="d-flex gap-2">
          <%= link_to edit_inquiry_path(@inquiry), class: "btn btn-sm btn-outline-secondary" do %>
            <i class="bi bi-pencil"></i>
          <% end %>
          <%= button_to inquiry_path(@inquiry), method: :delete, class: "btn btn-sm btn-outline-danger",
                data: { confirm: "정말 삭제하시겠습니까?" } do %>
            <i class="bi bi-trash"></i>
          <% end %>
        </div>
      <% end %>
    </div>

    <hr>
    <div style="line-height:1.9;color:#333;">
      <%= simple_format @inquiry.content %>
    </div>

    <% if @inquiry.product.present? %>
      <div class="mt-3 p-3 rounded-3" style="background:#f8f6f0;">
        <p class="small text-muted mb-1">관련 상품</p>
        <%= link_to @inquiry.product.name, product_path(@inquiry.product), class: "fw-semibold text-decoration-none text-dark" %>
      </div>
    <% end %>
  </div>

  <!-- Answers -->
  <% if @inquiry.answers.any? %>
    <h6 class="fw-semibold mb-3">답변</h6>
    <% @inquiry.answers.each do |answer| %>
      <div class="card border-0 shadow-sm rounded-4 p-4 mb-3" style="border-left:4px solid #e8b86d !important; background:#fffdf7;">
        <div class="d-flex align-items-center gap-2 mb-2">
          <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;background:#1a1a2e;color:#e8b86d;font-size:0.75rem;font-weight:700;">
            <%= answer.user.admin? ? "관리" : "판매" %>
          </div>
          <div>
            <p class="fw-semibold mb-0 small"><%= answer.user.name %></p>
            <p class="text-muted mb-0" style="font-size:0.7rem;"><%= answer.created_at.strftime("%Y.%m.%d %H:%M") %></p>
          </div>
        </div>
        <div style="line-height:1.9;color:#333;font-size:0.95rem;">
          <%= simple_format answer.content %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Answer Form (admin/seller) -->
  <% if user_signed_in? && (current_user.admin? || current_user.seller?) && @inquiry.status != 'closed' %>
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
      <h6 class="fw-semibold mb-3"><i class="bi bi-reply me-2"></i>답변 작성</h6>
      <%= form_with model: [@inquiry, Answer.new], local: true do |f| %>
        <%= f.text_area :content, rows: 4, placeholder: "답변을 입력해주세요...", class: "form-control mb-3" %>
        <div class="d-flex gap-2 justify-content-end">
          <%= f.submit "답변 등록", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="d-flex justify-content-between">
    <%= link_to "← 목록으로", inquiries_path, class: "btn btn-outline-secondary" %>
    <% if user_signed_in? %>
      <%= link_to "새 문의 작성", new_inquiry_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>